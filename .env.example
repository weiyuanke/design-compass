# Kagent Kubernetes 运维专家 — 对接 kagent-controller API
# 开发环境若遇 CORS，可设 VITE_KAGENT_BASE_URL=/kagent-proxy，并在 vite 里用 VITE_KAGENT_PROXY_TARGET 指向真实服务

# 必填：Kagent Controller 根地址（无尾部斜杠）
# VITE_KAGENT_BASE_URL=http://192.168.3.211:8083

# Vite 开发代理目标（默认同 VITE_KAGENT_BASE_URL）
# VITE_KAGENT_PROXY_TARGET=http://192.168.3.211:8083

# 可选
# VITE_KAGENT_USER_ID=admin@kagent.dev